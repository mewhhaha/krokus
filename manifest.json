{
  "manifest_version": 2,
  "name": "Friction Switch",
  "version": "0.1.0",
  "description": "Toggle annoying web behavior on purpose.",
  "permissions": [
    "storage",
    "*://*.youtube.com/*",
    "*://*.reddit.com/*"
  ],
  "browser_action": {
    "default_title": "Friction Switch",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content/common.js",
        "content/youtube.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.reddit.com/*"
      ],
      "js": [
        "content/common.js",
        "content/reddit.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "friction-switch@example.com",
      "strict_min_version": "109.0"
    }
  }
}
